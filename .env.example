# ── WhatsApp Business API ──────────────────────────────────────────────────────
# Referred to as WHATSAPP_TOKEN in project docs; the code reads WHATSAPP_ACCESS_TOKEN
# (kept as-is to match the already-deployed production variable name).
WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token_here
PHONE_NUMBER_ID=1046477205222937
VERIFY_TOKEN=alyafour_webhook_2024
# WhatsApp Business Account ID — required for the admin "New Conversation"
# feature to list approved message templates (Meta Business Manager > WhatsApp
# Business Accounts).
WHATSAPP_BUSINESS_ACCOUNT_ID=your_whatsapp_business_account_id

# ── Anthropic Claude AI ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Upstash Redis (free at upstash.com) — temporary bot session state ─────────
UPSTASH_REDIS_REST_URL=your_upstash_redis_url
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_token

# ── Neon PostgreSQL (free at neon.tech) — permanent conversations/messages ────
DATABASE_URL=postgresql://user:password@ep-example-000000.region.aws.neon.tech/neondb?sslmode=require

# ── Admin dashboard authentication ────────────────────────────────────────────
# Generate with: openssl rand -base64 48
AUTH_SECRET=replace_with_a_long_random_secret

# ── Deployment ─────────────────────────────────────────────────────────────────
APP_URL=https://your-app.vercel.app
